<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:app="clr-namespace:Spektra.App"
        x:Class="Spektra.App.DuplicatesWindow"
        Title="Duplicate Detective" Width="980" Height="680"
        Background="#111111" Foreground="#CCCCCC" FontSize="13"
        DragDrop.AllowDrop="True">
  <!-- Every expander in the window (group boxes, not-analyzed foldout) gets a
       compact custom header: chevron LEFT of the title (Fluent puts it right),
       both vertically centered. Retemplating the header ToggleButton drops the
       Fluent band, so headers read as section titles above the bordered
       content; the hover tint keeps them feeling clickable. -->
  <Window.Styles>
    <Style Selector="Expander">
      <Setter Property="Padding" Value="6,2" />
    </Style>
    <Style Selector="Expander /template/ ToggleButton">
      <Setter Property="Template">
        <ControlTemplate TargetType="ToggleButton">
          <Border Name="HeaderBand" Background="Transparent" MinHeight="30" Padding="10,4"
                  CornerRadius="4" Cursor="Hand">
            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
              <Path Name="PART_Chevron" Data="M 0 0 L 4 4 L 8 0" Stroke="#999999"
                    StrokeThickness="1.5" VerticalAlignment="Center"
                    RenderTransformOrigin="50%,50%" />
              <ContentPresenter Content="{TemplateBinding Content}" VerticalAlignment="Center" />
            </StackPanel>
          </Border>
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="Expander /template/ ToggleButton:pointerover /template/ Border#HeaderBand">
      <Setter Property="Background" Value="#1E1E1E" />
    </Style>
    <Style Selector="Expander /template/ ToggleButton:checked /template/ Path#PART_Chevron">
      <Setter Property="RenderTransform" Value="rotate(180deg)" />
    </Style>
  </Window.Styles>
  <!-- Bottom inset 4 (not 12) so the footer band matches the main window,
       whose status line sits 4px off the edge. -->
  <DockPanel Margin="12,12,12,4">
    <!-- Row 0 is the star row: the roots list absorbs any slack height (the
         buttons column is usually the tallest thing here), so the path box
         below keeps its compact height instead of stretching. While a scan
         runs, everything that edits the folder list disables: the run
         snapshotted the list at start, so a mid-scan edit would only desync
         what is shown from what the results cover. -->
    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto,Auto" RowDefinitions="*,Auto" Margin="0,0,0,8">
      <ListBox x:Name="RootsList" Grid.Row="0" Grid.Column="0" ItemsSource="{Binding Roots}"
               MaxHeight="120" Background="#181818"
               ToolTip.Tip="Folders the scan walks; duplicates are found across all of them">
        <ListBox.Styles>
          <Style Selector="ListBoxItem">
            <Setter Property="MinHeight" Value="22" />
            <Setter Property="Padding" Value="8,2" />
          </Style>
        </ListBox.Styles>
      </ListBox>
      <TextBox x:Name="RootPathBox" Grid.Row="1" Grid.Column="0" Margin="0,6,0,0"
               MinHeight="26" Padding="6,3" VerticalContentAlignment="Center"
               IsEnabled="{Binding !IsScanning}"
               PlaceholderText="Paste or type a folder path and press Enter"
               KeyDown="OnRootPathKeyDown"
               ToolTip.Tip="Adds the folder as a scan root; dragging folders from Explorer works too" />
      <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Width="1" Background="#2A2A2A"
              Margin="10,0" />
      <StackPanel Grid.Row="0" Grid.RowSpan="2" Grid.Column="2" Spacing="4" Width="130">
        <!-- Five actions share the column now: compact heights (matching the
             26px input boxes) and tighter spacing keep the stack at the old
             four-button height, so the header band does not grow. :is() also
             catches the DropDownButton, which derives from Button. -->
        <StackPanel.Styles>
          <Style Selector=":is(Button)">
            <Setter Property="MinHeight" Value="26" />
            <Setter Property="Padding" Value="10,3" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
          </Style>
        </StackPanel.Styles>
        <Button Content="Add folder…" Click="OnAddFolderClicked" HorizontalAlignment="Stretch"
                IsEnabled="{Binding !IsScanning}" />
        <Button Content="Remove" Click="OnRemoveFolderClicked" HorizontalAlignment="Stretch"
                IsEnabled="{Binding !IsScanning}" />
        <Button Content="Clear all" Click="OnClearFoldersClicked" HorizontalAlignment="Stretch"
                IsEnabled="{Binding !IsScanning}"
                ToolTip.Tip="Empty the folder list; the last results stay until the next scan" />
        <Button Content="Scan" Click="OnScanClicked" IsEnabled="{Binding CanScan}"
                IsVisible="{Binding !IsScanning}" HorizontalAlignment="Stretch" />
        <Button Content="Cancel" Click="OnCancelClicked" IsVisible="{Binding IsScanning}"
                HorizontalAlignment="Stretch" />
        <DropDownButton Content="Export" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                        IsEnabled="{Binding CanExport}" PointerEntered="OnExportHover"
                        ToolTip.Tip="Hover to pick HTML, CSV, or JSON">
          <DropDownButton.Flyout>
            <MenuFlyout>
              <MenuItem Header="HTML page" Tag="html" Click="OnExportFormatClicked" />
              <MenuItem Header="CSV rows" Tag="csv" Click="OnExportFormatClicked" />
              <MenuItem Header="JSON rows" Tag="json" Click="OnExportFormatClicked" />
            </MenuFlyout>
          </DropDownButton.Flyout>
        </DropDownButton>
      </StackPanel>
    </Grid>

    <!-- Splits the input bar (roots + path + buttons) from the results below;
         full-width via the negative margin that cancels the 12px inset. -->
    <Border DockPanel.Dock="Top" Height="1" Background="#2A2A2A" Margin="-12,0,-12,8" />

    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8" IsVisible="{Binding IsScanning}">
      <TextBlock DockPanel.Dock="Right" Text="{Binding ProgressText}" Margin="12,0,0,0"
                 VerticalAlignment="Center" Foreground="#999999" FontSize="12" />
      <ProgressBar Minimum="0" Maximum="1" Value="{Binding ProgressFraction}" Height="8" />
    </DockPanel>

    <StackPanel DockPanel.Dock="Bottom" Margin="0,4,0,0" Spacing="4">
      <Expander IsVisible="{Binding !!NotAnalyzed.Count}" HorizontalAlignment="Stretch">
        <Expander.Header>
          <TextBlock Text="{Binding NotAnalyzed.Count, StringFormat='{}{0} file(s) not analyzed'}"
                     Foreground="#CCCCCC" />
        </Expander.Header>
        <ItemsControl ItemsSource="{Binding NotAnalyzed}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <TextBlock FontSize="12" Foreground="#999999">
                <Run Text="{Binding Path}" /><Run Text=" · " /><Run Text="{Binding Reason}" />
              </TextBlock>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </Expander>
      <TextBlock Text="{Binding FooterText}" Foreground="#888888" FontSize="11" />
    </StackPanel>

    <!-- Splits the results from the footer, mirroring the top-bar divider. -->
    <Border DockPanel.Dock="Bottom" Height="1" Background="#2A2A2A" Margin="-12,8,-12,0" />

    <ScrollViewer>
      <ItemsControl ItemsSource="{Binding Groups}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="app:DupeGroupItem">
            <Expander IsExpanded="{Binding IsSmall}" Margin="0,3" HorizontalAlignment="Stretch"
                      BorderBrush="#2E2E2E" BorderThickness="1" CornerRadius="4">
              <Expander.Header>
                <TextBlock Text="{Binding Headline}" Foreground="#DDDDDD" />
              </Expander.Header>
              <StackPanel>
                <ItemsControl ItemsSource="{Binding Members}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="app:DupeMemberItem">
                      <!-- One line per copy: the path fills the row and the
                           verdict facts sit in fixed lanes, so they read as
                           columns across every group. -->
                      <Grid ColumnDefinitions="18,12,*,60,110,64,76,104,96" Margin="4,2"
                            Background="Transparent" DoubleTapped="OnMemberDoubleTapped"
                            ToolTip.Tip="{Binding Path}">
                        <Grid.ContextMenu>
                          <ContextMenu>
                            <MenuItem Header="_Open spectrogram" Click="OnOpenMemberClicked" />
                            <Separator />
                            <MenuItem Header="Copy _path" Click="OnCopyMemberPathClicked" />
                            <MenuItem Header="_Reveal in Explorer" Click="OnRevealMemberClicked" />
                          </ContextMenu>
                        </Grid.ContextMenu>
                        <TextBlock Grid.Column="0" Text="★" Foreground="#D8B060"
                                   VerticalAlignment="Center" IsVisible="{Binding IsWinner}"
                                   ToolTip.Tip="The copy worth keeping" />
                        <Ellipse Grid.Column="1" Width="8" Height="8" VerticalAlignment="Center"
                                 Fill="{Binding IntegrityBrush}" ToolTip.Tip="Integrity" />
                        <TextBlock Grid.Column="2" Text="{Binding Path}" Margin="8,0,8,0"
                                   TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="3" Text="{Binding Codec}" Foreground="#999999"
                                   FontSize="12" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="4" Text="{Binding Bandwidth}" Foreground="#999999"
                                   FontSize="12" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="5" Text="{Binding Integrity}"
                                   Foreground="{Binding IntegrityBrush}" FontSize="12"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="6" Text="{Binding SizeText}" Foreground="#999999"
                                   FontSize="12" TextAlignment="Right" Margin="0,0,16,0"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="7" Text="{Binding SamenessText}" Foreground="#999999"
                                   FontSize="12" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="8" Text="found by audio" Foreground="#6FB3E8"
                                   FontSize="12" VerticalAlignment="Center"
                                   IsVisible="{Binding FoundByAudio}"
                                   ToolTip.Tip="Matched by fingerprint despite an unrelated name" />
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Text="{Binding QualityLine}" Foreground="#999999" FontSize="12"
                           Margin="34,2,0,4" />
              </StackPanel>
            </Expander>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </DockPanel>
</Window>
