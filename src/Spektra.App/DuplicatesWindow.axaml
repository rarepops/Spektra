<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:app="clr-namespace:Spektra.App"
        x:Class="Spektra.App.DuplicatesWindow"
        Title="Duplicate Detective" Width="980" Height="680"
        Background="#111111" Foreground="#CCCCCC" FontSize="13"
        DragDrop.AllowDrop="True">
  <!-- The Fluent Expander is generous by default (48px header, wide content
       padding); these compact every expander in the window: the group boxes
       and the not-analyzed foldout. Padding reaches the content border via
       TemplateBinding; the template's only ToggleButton is the header. -->
  <Window.Styles>
    <Style Selector="Expander">
      <Setter Property="Padding" Value="6,2" />
    </Style>
    <Style Selector="Expander /template/ ToggleButton">
      <Setter Property="MinHeight" Value="30" />
      <Setter Property="Padding" Value="10,4" />
    </Style>
  </Window.Styles>
  <DockPanel Margin="12">
    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" Margin="0,0,0,8">
      <ListBox x:Name="RootsList" Grid.Row="0" Grid.Column="0" ItemsSource="{Binding Roots}"
               MaxHeight="92" Background="#181818"
               ToolTip.Tip="Folders the scan walks; duplicates are found across all of them">
        <ListBox.Styles>
          <Style Selector="ListBoxItem">
            <Setter Property="MinHeight" Value="22" />
            <Setter Property="Padding" Value="8,2" />
          </Style>
        </ListBox.Styles>
      </ListBox>
      <TextBox x:Name="RootPathBox" Grid.Row="1" Grid.Column="0" Margin="0,6,0,0"
               MinHeight="26" Padding="6,3" VerticalContentAlignment="Center"
               PlaceholderText="Paste or type a folder path and press Enter"
               KeyDown="OnRootPathKeyDown"
               ToolTip.Tip="Adds the folder as a scan root; dragging folders from Explorer works too" />
      <StackPanel Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Margin="8,0,0,0" Spacing="6" Width="130">
        <Button Content="Add folder…" Click="OnAddFolderClicked" HorizontalAlignment="Stretch" />
        <Button Content="Remove" Click="OnRemoveFolderClicked" HorizontalAlignment="Stretch" />
        <Button Content="Scan" Click="OnScanClicked" IsEnabled="{Binding CanScan}"
                IsVisible="{Binding !IsScanning}" HorizontalAlignment="Stretch" />
        <Button Content="Cancel" Click="OnCancelClicked" IsVisible="{Binding IsScanning}"
                HorizontalAlignment="Stretch" />
        <Button Content="Export…" Click="OnExportClicked" HorizontalAlignment="Stretch"
                ToolTip.Tip="Save the groups as HTML, CSV, or JSON" />
      </StackPanel>
    </Grid>

    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8" IsVisible="{Binding IsScanning}">
      <TextBlock DockPanel.Dock="Right" Text="{Binding ProgressText}" Margin="12,0,0,0"
                 VerticalAlignment="Center" Foreground="#999999" FontSize="12" />
      <ProgressBar Minimum="0" Maximum="1" Value="{Binding ProgressFraction}" Height="8" />
    </DockPanel>

    <StackPanel DockPanel.Dock="Bottom" Margin="0,8,0,0" Spacing="4">
      <Expander IsVisible="{Binding !!NotAnalyzed.Count}" HorizontalAlignment="Stretch">
        <Expander.Header>
          <TextBlock Text="{Binding NotAnalyzed.Count, StringFormat='{}{0} file(s) not analyzed'}"
                     Foreground="#CCCCCC" />
        </Expander.Header>
        <ItemsControl ItemsSource="{Binding NotAnalyzed}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <TextBlock FontSize="12" Foreground="#999999">
                <Run Text="{Binding Path}" /><Run Text=" · " /><Run Text="{Binding Reason}" />
              </TextBlock>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </Expander>
      <TextBlock Text="{Binding FooterText}" Foreground="#999999" FontSize="12" />
    </StackPanel>

    <ScrollViewer>
      <ItemsControl ItemsSource="{Binding Groups}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="app:DupeGroupItem">
            <Expander IsExpanded="{Binding IsSmall}" Margin="0,3" HorizontalAlignment="Stretch"
                      BorderBrush="#2E2E2E" BorderThickness="1" CornerRadius="4">
              <Expander.Header>
                <TextBlock Text="{Binding Headline}" Foreground="#EEEEEE" />
              </Expander.Header>
              <StackPanel>
                <ItemsControl ItemsSource="{Binding Members}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="app:DupeMemberItem">
                      <!-- One line per copy: the path fills the row and the
                           verdict facts sit in fixed lanes, so they read as
                           columns across every group. -->
                      <Grid ColumnDefinitions="18,12,*,60,110,64,76,104,96" Margin="4,2"
                            Background="Transparent" DoubleTapped="OnMemberDoubleTapped"
                            ToolTip.Tip="{Binding Path}">
                        <Grid.ContextMenu>
                          <ContextMenu>
                            <MenuItem Header="Copy _path" Click="OnCopyMemberPathClicked" />
                            <MenuItem Header="_Reveal in Explorer" Click="OnRevealMemberClicked" />
                          </ContextMenu>
                        </Grid.ContextMenu>
                        <TextBlock Grid.Column="0" Text="★" Foreground="#D8B060"
                                   VerticalAlignment="Center" IsVisible="{Binding IsWinner}"
                                   ToolTip.Tip="The copy worth keeping" />
                        <Ellipse Grid.Column="1" Width="8" Height="8" VerticalAlignment="Center"
                                 Fill="{Binding IntegrityBrush}" ToolTip.Tip="Integrity" />
                        <TextBlock Grid.Column="2" Text="{Binding Path}" Margin="8,0,8,0"
                                   TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="3" Text="{Binding Codec}" Foreground="#999999"
                                   FontSize="12" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="4" Text="{Binding Bandwidth}" Foreground="#999999"
                                   FontSize="12" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="5" Text="{Binding Integrity}"
                                   Foreground="{Binding IntegrityBrush}" FontSize="12"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="6" Text="{Binding SizeText}" Foreground="#999999"
                                   FontSize="12" TextAlignment="Right" Margin="0,0,16,0"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="7" Text="{Binding SamenessText}" Foreground="#999999"
                                   FontSize="12" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="8" Text="found by audio" Foreground="#6FB3E8"
                                   FontSize="12" VerticalAlignment="Center"
                                   IsVisible="{Binding FoundByAudio}"
                                   ToolTip.Tip="Matched by fingerprint despite an unrelated name" />
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Text="{Binding QualityLine}" Foreground="#999999" FontSize="12"
                           Margin="34,2,0,4" />
              </StackPanel>
            </Expander>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>
  </DockPanel>
</Window>
