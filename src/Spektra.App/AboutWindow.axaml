<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Spektra.App.AboutWindow"
        Title="About Spektra" Width="440" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" Background="#1A1A1A" CanResize="False">
  <Window.Styles>
    <Style Selector="TextBlock.link">
      <Setter Property="Foreground" Value="#8AB4F8" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="TextBlock.link:pointerover">
      <Setter Property="Foreground" Value="#AECBFA" />
      <Setter Property="TextDecorations" Value="Underline" />
    </Style>
  </Window.Styles>
  <StackPanel Margin="20" Spacing="14">
    <StackPanel Orientation="Horizontal" Spacing="16">
      <Image Source="/Assets/spektra-logo.png" Width="72" Height="72" VerticalAlignment="Top" />
      <StackPanel VerticalAlignment="Center" Spacing="3">
        <TextBlock Text="Spektra" FontSize="24" FontWeight="SemiBold" Foreground="#EDEDED" />
        <TextBlock x:Name="VersionText" Foreground="#9AA0A6" FontSize="13" />
        <TextBlock Text="Audio spectrum analyzer and encode comparator"
                   Foreground="#BBBBBB" FontSize="12" TextWrapping="Wrap" />
      </StackPanel>
    </StackPanel>

    <Border Height="1" Background="#2E2E2E" />

    <Grid ColumnDefinitions="70,*" RowDefinitions="Auto,Auto" RowSpacing="6">
      <TextBlock Grid.Row="0" Grid.Column="0" Text="Runtime" Foreground="#9A9A9A" FontSize="12" />
      <TextBlock Grid.Row="0" Grid.Column="1" x:Name="RuntimeText"
                 Foreground="#C9C9C9" FontSize="12" TextWrapping="Wrap" />
      <TextBlock Grid.Row="1" Grid.Column="0" Text="ffmpeg" Foreground="#9A9A9A" FontSize="12" />
      <TextBlock Grid.Row="1" Grid.Column="1" x:Name="FfmpegText"
                 Foreground="#C9C9C9" FontSize="12" TextWrapping="Wrap" />
    </Grid>

    <Border Height="1" Background="#2E2E2E" />

    <TextBlock TextWrapping="Wrap" Foreground="#8C8C8C" FontSize="11">
      Audio is decoded with ffmpeg / ffprobe as separate processes; they are not bundled or linked.
      Licensed under PolyForm Perimeter 1.0.1. © Rares (rarepops).
    </TextBlock>

    <Border Height="1" Background="#2E2E2E" />

    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
      <TextBlock Classes="link" Text="Controls" PointerPressed="OnControls" />
      <TextBlock Text="·" Foreground="#5A5A5A" FontSize="12" />
      <TextBlock Classes="link" Text="GitHub" PointerPressed="OnGitHub" />
      <TextBlock Text="·" Foreground="#5A5A5A" FontSize="12" />
      <TextBlock Classes="link" Text="License" PointerPressed="OnLicense" />
    </StackPanel>

    <Grid ColumnDefinitions="Auto,*,Auto">
      <Button Grid.Column="0" Content="Copy info" Click="OnCopyInfo" />
      <Button Grid.Column="2" Content="Close" Click="OnClose" IsDefault="True" IsCancel="True" />
    </Grid>
  </StackPanel>
</Window>
