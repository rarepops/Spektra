<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Spektra.App.PreferencesWindow"
        Title="Preferences" Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" Background="#1A1A1A" CanResize="False">
  <StackPanel Margin="20" Spacing="16">

    <TextBlock Text="Analysis" Foreground="#9AA0A6" FontSize="12" FontWeight="SemiBold" />
    <Grid ColumnDefinitions="150,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="10">
      <TextBlock Grid.Row="0" Grid.Column="0" Text="FFT window size" Foreground="#C9C9C9"
                 FontSize="12" VerticalAlignment="Center" />
      <ComboBox Grid.Row="0" Grid.Column="1" HorizontalAlignment="Stretch"
                ItemsSource="{Binding FftSizes}" SelectedItem="{Binding FftSize, Mode=TwoWay}" />
      <TextBlock Grid.Row="1" Grid.Column="0" Text="Window function" Foreground="#C9C9C9"
                 FontSize="12" VerticalAlignment="Center" />
      <ComboBox Grid.Row="1" Grid.Column="1" HorizontalAlignment="Stretch"
                ItemsSource="{Binding WindowFunctions}" SelectedItem="{Binding WindowFunction, Mode=TwoWay}" />
      <TextBlock Grid.Row="2" Grid.Column="0" Text="Folder analysis order" Foreground="#C9C9C9"
                 FontSize="12" VerticalAlignment="Center" />
      <ComboBox Grid.Row="2" Grid.Column="1" HorizontalAlignment="Stretch"
                ItemsSource="{Binding FolderAnalysisOrders}"
                SelectedIndex="{Binding FolderAnalysisOrderIndex, Mode=TwoWay}"
                ToolTip.Tip="Scheduling only (analysis stays parallel) · applies from the next run" />
      <TextBlock Grid.Row="3" Grid.Column="0" Text="Integrity check" Foreground="#C9C9C9"
                 FontSize="12" VerticalAlignment="Center" />
      <CheckBox Grid.Row="3" Grid.Column="1" Content="Run on every opened file" Foreground="#C9C9C9"
                IsChecked="{Binding AutoIntegrityCheck, Mode=TwoWay}"
                ToolTip.Tip="Runs in the background beside the spectrogram · applies to files opened afterwards · Ctrl+I works either way" />
    </Grid>

    <Border Height="1" Background="#2E2E2E" />

    <TextBlock Text="Display" Foreground="#9AA0A6" FontSize="12" FontWeight="SemiBold" />
    <Grid ColumnDefinitions="150,*" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="10">
      <TextBlock Grid.Row="0" Grid.Column="0" Text="Color palette" Foreground="#C9C9C9"
                 FontSize="12" VerticalAlignment="Center" />
      <ComboBox Grid.Row="0" Grid.Column="1" HorizontalAlignment="Stretch"
                ItemsSource="{Binding Palettes}" SelectedItem="{Binding Palette, Mode=TwoWay}" />

      <TextBlock Grid.Row="1" Grid.Column="0" Text="Tightness" Foreground="#C9C9C9"
                 FontSize="12" VerticalAlignment="Center" />
      <DockPanel Grid.Row="1" Grid.Column="1">
        <TextBlock DockPanel.Dock="Right" Width="52" TextAlignment="Right" Foreground="#9A9A9A" FontSize="12"
                   VerticalAlignment="Center" Text="{Binding Tightness, StringFormat='{}{0:0.00}'}" />
        <Slider Minimum="0.5" Maximum="2.5" TickFrequency="0.05" IsSnapToTickEnabled="True"
                Value="{Binding Tightness, Mode=TwoWay}"
                ToolTip.Tip="Higher = tighter peaks, lower = bloomier · 1.00 = untouched" />
      </DockPanel>

      <TextBlock Grid.Row="2" Grid.Column="0" Text="Dynamic range floor" Foreground="#C9C9C9"
                 FontSize="12" VerticalAlignment="Center" />
      <DockPanel Grid.Row="2" Grid.Column="1">
        <TextBlock DockPanel.Dock="Right" Width="52" TextAlignment="Right" Foreground="#9A9A9A" FontSize="12"
                   VerticalAlignment="Center" Text="{Binding DbFloor, StringFormat='{}{0} dB'}" />
        <Slider Minimum="-140" Maximum="-40" TickFrequency="10" IsSnapToTickEnabled="True"
                Value="{Binding DbFloor, Mode=TwoWay}"
                ToolTip.Tip="Lower = reveal more quiet detail; higher = show only louder content" />
      </DockPanel>

      <TextBlock Grid.Row="3" Grid.Column="0" Text="Frequency axis" Foreground="#C9C9C9"
                 FontSize="12" VerticalAlignment="Center" />
      <CheckBox Grid.Row="3" Grid.Column="1" Content="Logarithmic" Foreground="#C9C9C9"
                IsChecked="{Binding LogFrequency, Mode=TwoWay}" />
    </Grid>

    <Border Height="1" Background="#2E2E2E" />

    <TextBlock Text="Session" Foreground="#9AA0A6" FontSize="12" FontWeight="SemiBold" />
    <CheckBox Content="Reopen last session's tabs on launch" Foreground="#C9C9C9"
              IsChecked="{Binding RestoreSession, Mode=TwoWay}"
              ToolTip.Tip="Only on a bare launch · opening a file directly stays targeted" />

    <Border Height="1" Background="#2E2E2E" />

    <TextBlock Text="Updates" Foreground="#9AA0A6" FontSize="12" FontWeight="SemiBold" />
    <CheckBox Content="Check for updates on startup" Foreground="#C9C9C9"
              IsChecked="{Binding CheckForUpdatesOnStartup, Mode=TwoWay}"
              ToolTip.Tip="Checks GitHub at most once a day" />

    <Border Height="1" Background="#2E2E2E" />

    <TextBlock TextWrapping="Wrap" Foreground="#8C8C8C" FontSize="11">
      FFT size and window function change the analysis and re-scan open files.
      Palette, tightness, dynamic range, and axis are display-only and apply instantly.
    </TextBlock>

    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
      <Button Content="Close" Click="OnClose" IsDefault="True" IsCancel="True" />
    </StackPanel>
  </StackPanel>
</Window>
