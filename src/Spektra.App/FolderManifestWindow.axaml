<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:app="clr-namespace:Spektra.App"
        x:Class="Spektra.App.FolderManifestWindow"
        Title="Folder Manifest" Width="760" Height="640"
        Background="#111111" Foreground="#CCCCCC" FontSize="13"
        DragDrop.AllowDrop="True">
  <!-- Bottom inset 4 (not 12) so the footer band matches the main window,
       whose status line sits 4px off the edge. -->
  <DockPanel Margin="12,12,12,4">
    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto,Auto" RowDefinitions="Auto,Auto" Margin="0,0,0,8">
      <!-- Address bar: shows the folder being listed AND accepts a new one, so
           there is no separate unframed label row. OneWay on purpose: Folder
           has a private setter, so a default (TwoWay) TextBox binding would
           try to write back and fail; OneWay lets typing stay local until
           Enter, then a completed load rewrites the box with the real path. -->
      <!-- VerticalAlignment on both boxes: the button stack beside them is
           taller than the two rows, so the grid grows the rows to fit it.
           Without this the boxes stretch by different amounts (row 1 carries
           a 6px top margin) and end up visibly unequal. -->
      <TextBox x:Name="ManifestPathBox" Grid.Row="0" Grid.Column="0"
               MinHeight="26" Padding="6,3" VerticalContentAlignment="Center"
               VerticalAlignment="Center"
               Text="{Binding Folder, Mode=OneWay}"
               PlaceholderText="Paste or type a folder path and press Enter"
               KeyDown="OnManifestPathKeyDown"
               ToolTip.Tip="The folder being listed · type another and press Enter (Esc to revert); dragging a folder from Explorer works too" />
      <TextBox Grid.Row="1" Grid.Column="0" Margin="0,6,0,0"
               MinHeight="26" Padding="6,3" VerticalContentAlignment="Center"
               VerticalAlignment="Center"
               Text="{Binding FilterText}"
               PlaceholderText="Filter by extension, space separated: flac jpg nfo"
               ToolTip.Tip="Shows only files whose kind or extension matches; folders without matches disappear and Export writes exactly what is shown" />
      <!-- Splits the inputs from the actions, matching the Duplicate Detective
           header: the rule makes the button column its own region, so the
           space below the last button reads as intentional rather than as a
           gap in the input stack. -->
      <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="1" Width="1" Background="#2A2A2A"
              Margin="10,0" />
      <StackPanel Grid.Row="0" Grid.RowSpan="2" Grid.Column="2" Spacing="4" Width="130">
        <!-- Same compact style as the Duplicate Detective's column: 26px to
             match the input boxes, so the sibling windows read alike. -->
        <StackPanel.Styles>
          <Style Selector=":is(Button)">
            <Setter Property="MinHeight" Value="26" />
            <Setter Property="Padding" Value="10,3" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
          </Style>
        </StackPanel.Styles>
        <Button Content="Browse…" Click="OnPickFolderClicked" HorizontalAlignment="Stretch"
                IsVisible="{Binding !IsLoading}" />
        <Button Content="Cancel" Click="OnCancelLoadClicked" HorizontalAlignment="Stretch"
                IsVisible="{Binding IsLoading}"
                ToolTip.Tip="Stop listing this folder" />
        <DropDownButton Content="Export" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                        IsEnabled="{Binding CanExport}" PointerEntered="OnExportHover"
                        ToolTip.Tip="Hover to pick HTML, CSV, or JSON">
          <DropDownButton.Flyout>
            <MenuFlyout>
              <MenuItem Header="HTML page" Tag="html" Click="OnExportFormatClicked" />
              <MenuItem Header="CSV rows" Tag="csv" Click="OnExportFormatClicked" />
              <MenuItem Header="JSON rows" Tag="json" Click="OnExportFormatClicked" />
            </MenuFlyout>
          </DropDownButton.Flyout>
        </DropDownButton>
      </StackPanel>
    </Grid>

    <!-- Full-width divider between the input bar and the listing; the negative
         horizontal margin cancels the DockPanel's 12px inset so the line reaches
         both window edges like the main view. The header lanes bind to the same
         view-model widths as the file rows (whose grid adds a 4px right margin),
         so they stay aligned at any width; each fact lane's left edge carries an
         invisible drag grip, the same affordance as the audit grid's columns. -->
    <Border DockPanel.Dock="Top" Height="1" Background="#2A2A2A" Margin="-12,0,-12,6" />
    <Grid DockPanel.Dock="Top" ColumnDefinitions="*,Auto,Auto" Margin="0,0,6,6">
      <TextBlock Grid.Column="0" Text="Name" Foreground="#888888" FontSize="11" />
      <TextBlock Grid.Column="1" Text="Kind" Foreground="#888888" FontSize="11"
                 Width="{Binding KindLaneWidth}" />
      <TextBlock Grid.Column="2" Text="Size" Foreground="#888888" FontSize="11"
                 Width="{Binding SizeLaneWidth}" TextAlignment="Right" />
      <Thumb Grid.Column="1" Width="8" Margin="-4,0,0,0" HorizontalAlignment="Left"
             Cursor="SizeWestEast" DragDelta="OnKindLaneDrag">
        <Thumb.Template>
          <ControlTemplate>
            <Border Background="Transparent" />
          </ControlTemplate>
        </Thumb.Template>
      </Thumb>
      <Thumb Grid.Column="2" Width="8" Margin="-4,0,0,0" HorizontalAlignment="Left"
             Cursor="SizeWestEast" DragDelta="OnSizeLaneDrag">
        <Thumb.Template>
          <ControlTemplate>
            <Border Background="Transparent" />
          </ControlTemplate>
        </Thumb.Template>
      </Thumb>
    </Grid>

    <TextBlock DockPanel.Dock="Bottom" Margin="0,4,0,0" Text="{Binding FooterText}"
               Foreground="#888888" FontSize="11" />
    <Border DockPanel.Dock="Bottom" Height="1" Background="#2A2A2A" Margin="-12,8,-12,0" />

    <TreeView ItemsSource="{Binding RootItems}" Background="Transparent">
      <TreeView.Styles>
        <Style Selector="TreeViewItem">
          <Setter Property="MinHeight" Value="22" />
          <Setter Property="Padding" Value="2,1" />
        </Style>
        <Style Selector="TreeView > TreeViewItem">
          <Setter Property="IsExpanded" Value="{Binding IsExpanded}" />
        </Style>
      </TreeView.Styles>
      <TreeView.DataTemplates>
        <TreeDataTemplate DataType="app:ManifestFolderItem" ItemsSource="{Binding Children}">
          <TextBlock Text="{Binding Header}" Foreground="#DDDDDD" Background="Transparent">
            <TextBlock.ContextMenu>
              <ContextMenu>
                <MenuItem Header="_Audit this folder" Click="OnMenuAuditFolderClicked"
                          ToolTip.Tip="Open it as a folder tab in the main window, ready to analyze" />
                <Separator />
                <MenuItem Header="Copy _path" Click="OnMenuCopyPathClicked" />
                <MenuItem Header="_Reveal in Explorer" Click="OnMenuRevealClicked" />
              </ContextMenu>
            </TextBlock.ContextMenu>
          </TextBlock>
        </TreeDataTemplate>
        <DataTemplate DataType="app:ManifestFileItem">
          <!-- Lane widths come from the view model (dragged at the header),
               so every row's kind and size stay under the column headers
               above the tree. -->
          <Grid ColumnDefinitions="*,Auto,Auto" Margin="0,0,4,0"
                Background="Transparent" ToolTip.Tip="{Binding Path}">
            <Grid.ContextMenu>
              <ContextMenu>
                <MenuItem Header="_Open spectrogram" Click="OnMenuOpenClicked"
                          IsEnabled="{Binding IsAudio}" />
                <Separator />
                <MenuItem Header="Copy _path" Click="OnMenuCopyPathClicked" />
                <MenuItem Header="_Reveal in Explorer" Click="OnMenuRevealClicked" />
              </ContextMenu>
            </Grid.ContextMenu>
            <TextBlock Grid.Column="0" Text="{Binding Name}" Margin="0,0,8,0"
                       TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
            <TextBlock Grid.Column="1" Text="{Binding Kind}" Foreground="{Binding KindBrush}"
                       FontSize="12" TextTrimming="CharacterEllipsis"
                       Width="{Binding $parent[TreeView].DataContext.KindLaneWidth}"
                       VerticalAlignment="Center" />
            <TextBlock Grid.Column="2" Text="{Binding SizeText}" Foreground="#999999" FontSize="12"
                       Width="{Binding $parent[TreeView].DataContext.SizeLaneWidth}"
                       TextAlignment="Right" VerticalAlignment="Center" />
          </Grid>
        </DataTemplate>
      </TreeView.DataTemplates>
    </TreeView>
  </DockPanel>
</Window>
