<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:app="clr-namespace:Spektra.App"
             x:Class="Spektra.App.Controls.FolderView"
             Background="#111111">
  <UserControl.Styles>
    <Style Selector="TextBlock.cell">
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="Foreground" Value="#CCCCCC" />
    </Style>
    <Style Selector="TextBlock.cell.bad">
      <Setter Property="Foreground" Value="#E08080" />
    </Style>
    <Style Selector="TextBlock.cell.up">
      <Setter Property="Foreground" Value="#B08FD8" />
    </Style>
  </UserControl.Styles>
  <UserControl.DataTemplates>
    <TreeDataTemplate DataType="app:FolderNodeViewModel"
                      ItemsSource="{Binding Children}">
      <StackPanel Orientation="Horizontal" Spacing="6">
        <CheckBox IsThreeState="True"
                  IsChecked="{Binding IsChecked, Mode=TwoWay}" />
        <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                 Fill="{Binding MarkerBrush}" />
        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
        <TextBlock Text="{Binding RollupText}" Opacity="0.6"
                   VerticalAlignment="Center" />
      </StackPanel>
    </TreeDataTemplate>
    <DataTemplate DataType="app:FileNodeViewModel">
      <StackPanel Orientation="Horizontal" Spacing="6">
        <CheckBox IsThreeState="False"
                  IsChecked="{Binding IsChecked, Mode=TwoWay}" />
        <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                 Fill="{Binding MarkerBrush}" />
        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
      </StackPanel>
    </DataTemplate>
  </UserControl.DataTemplates>
  <DockPanel>
    <DockPanel DockPanel.Dock="Top" Margin="12,8,12,6">
      <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
        <Button Content="Analyze" Click="OnAnalyzeClicked"
                IsEnabled="{Binding CanAnalyze}" IsVisible="{Binding !IsAnalyzing}"
                ToolTip.Tip="Analyze the checked files · Shift+click or Shift+F5 re-analyzes even cached ones" />
        <Button Content="Cancel" Click="OnCancelClicked"
                IsVisible="{Binding IsAnalyzing}" />
        <Button Content="Select all" Click="OnSelectAllClicked" />
        <Button Content="Select none" Click="OnSelectNoneClicked" />
        <Button Content="Drilldown" Click="OnDrilldownClicked" />
        <ComboBox ItemsSource="{Binding FilterOptions}" SelectedIndex="{Binding FilterIndex, Mode=TwoWay}"
                  MinWidth="140" FontSize="12" VerticalAlignment="Center"
                  ToolTip.Tip="Show rows at this severity and worse" />
        <Button Content="Export…" Click="OnExportClicked" IsEnabled="{Binding CanAnalyze}" />
      </StackPanel>
      <ProgressBar Minimum="0" Maximum="1" Value="{Binding ProgressFraction}"
                   Height="8" Margin="0,0,12,0" VerticalAlignment="Center" />
    </DockPanel>
    <Grid ColumnDefinitions="320,4,*">
      <TreeView x:Name="Tree" Grid.Column="0" ItemsSource="{Binding Roots}" />
      <GridSplitter Grid.Column="1" ResizeDirection="Columns" />
      <DockPanel Grid.Column="2">
        <Border DockPanel.Dock="Top" Padding="6" IsVisible="{Binding IsScoped}">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="{Binding ScopeBreadcrumb}" VerticalAlignment="Center" />
            <Button Content="Show all" Click="OnShowAllClicked" />
          </StackPanel>
        </Border>
        <DataGrid x:Name="Grid" IsReadOnly="True" AutoGenerateColumns="False"
                  CanUserSortColumns="True" CanUserReorderColumns="False"
                  Background="#111111" FontSize="12"
                  DoubleTapped="OnRowDoubleTapped" KeyDown="OnGridKeyDown">
          <DataGrid.Columns>
            <DataGridTextColumn Header="File" Binding="{Binding File}" Width="2*" />
            <DataGridTemplateColumn Header="Bandwidth" SortMemberPath="Bandwidth" Width="Auto">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <TextBlock Classes="cell" Classes.bad="{Binding BandwidthIsBad}"
                             Classes.up="{Binding BandwidthIsUpsampled}"
                             Text="{Binding Bandwidth}" Margin="12,0"
                             ToolTip.Tip="{Binding Error}" />
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
            <DataGridTextColumn Header="Cutoff kHz" Binding="{Binding CutoffKhz, StringFormat='0.0'}"
                                SortMemberPath="CutoffKhz" Width="Auto" />
            <DataGridTemplateColumn Header="Integrity" SortMemberPath="Integrity" Width="Auto">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <TextBlock Classes="cell" Classes.bad="{Binding IntegrityIsBad}"
                             Text="{Binding Integrity}" Margin="12,0" />
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
            <DataGridTextColumn Header="Codec" Binding="{Binding Codec}" Width="Auto" />
            <DataGridTextColumn Header="kbps" Binding="{Binding BitrateKbps, StringFormat='0'}"
                                SortMemberPath="BitrateKbps" Width="Auto" />
            <DataGridTextColumn Header="Hz" Binding="{Binding SampleRateHz}" Width="Auto" />
            <DataGridTextColumn Header="Length" Binding="{Binding DurationText}"
                                SortMemberPath="DurationSeconds" Width="Auto" />
            <DataGridTextColumn Header="Errors" Binding="{Binding DecodeErrors}" Width="Auto" />
            <DataGridTextColumn Header="Dropouts" Binding="{Binding Dropouts}" Width="Auto" />
          </DataGrid.Columns>
        </DataGrid>
      </DockPanel>
    </Grid>
  </DockPanel>
</UserControl>
