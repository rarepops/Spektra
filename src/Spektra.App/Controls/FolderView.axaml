<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:app="clr-namespace:Spektra.App"
             x:Class="Spektra.App.Controls.FolderView"
             Background="#111111">
  <UserControl.Styles>
    <Style Selector="TextBlock.cell">
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="Foreground" Value="#CCCCCC" />
    </Style>
    <Style Selector="TextBlock.cell.bad">
      <Setter Property="Foreground" Value="#E08080" />
    </Style>
    <Style Selector="TextBlock.cell.up">
      <Setter Property="Foreground" Value="#B08FD8" />
    </Style>
  </UserControl.Styles>
  <UserControl.DataTemplates>
    <TreeDataTemplate DataType="app:FolderNodeViewModel"
                      ItemsSource="{Binding Children}">
      <StackPanel Orientation="Horizontal" Spacing="6">
        <CheckBox IsThreeState="True"
                  IsChecked="{Binding IsChecked, Mode=TwoWay}" />
        <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                 Fill="{Binding MarkerBrush}" />
        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
        <TextBlock Text="{Binding RollupText}" Opacity="0.6"
                   VerticalAlignment="Center" />
      </StackPanel>
    </TreeDataTemplate>
    <DataTemplate DataType="app:FileNodeViewModel">
      <StackPanel Orientation="Horizontal" Spacing="6">
        <CheckBox IsThreeState="False"
                  IsChecked="{Binding IsChecked, Mode=TwoWay}" />
        <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                 Fill="{Binding MarkerBrush}" />
        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
      </StackPanel>
    </DataTemplate>
  </UserControl.DataTemplates>
  <DockPanel>
    <DockPanel DockPanel.Dock="Top" Margin="12,8,12,6">
      <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
        <Button Content="Analyze" Click="OnAnalyzeClicked"
                IsEnabled="{Binding CanAnalyze}" IsVisible="{Binding !IsAnalyzing}"
                ToolTip.Tip="Analyze checked files · Shift re-analyzes cached ones" />
        <Button Content="Cancel" Click="OnCancelClicked"
                IsVisible="{Binding IsAnalyzing}"
                ToolTip.Tip="Stop · finished rows are kept" />
      </StackPanel>
      <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
        <ComboBox ItemsSource="{Binding FilterOptions}" SelectedIndex="{Binding FilterIndex, Mode=TwoWay}"
                  MinWidth="140" FontSize="12" VerticalAlignment="Center"
                  ToolTip.Tip="Show rows at this severity and worse" />
        <Button Content="Export…" Click="OnExportClicked" IsEnabled="{Binding CanAnalyze}"
                ToolTip.Tip="Save the grid as CSV or JSON" />
      </StackPanel>
      <TextBlock DockPanel.Dock="Right" Text="{Binding AnalyzeProgress}"
                 IsVisible="{Binding IsAnalyzing}" FontSize="12" Foreground="#CCCCCC"
                 VerticalAlignment="Center" Margin="0,0,12,0" />
      <ProgressBar Minimum="0" Maximum="1" Value="{Binding ProgressFraction}"
                   Height="8" Margin="12,0,12,0" VerticalAlignment="Center" />
    </DockPanel>
    <Border DockPanel.Dock="Top" Height="1" Background="#2E2E2E" />
    <Grid x:Name="Split" ColumnDefinitions="320,4,*">
      <Border Grid.Column="0" Padding="4,4,4,0"
              BorderBrush="#2E2E2E" BorderThickness="0,0,1,0">
        <DockPanel>
          <Grid DockPanel.Dock="Top" ColumnDefinitions="Auto,*,Auto"
                Margin="0,0,0,4">
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4">
              <Button Content="All" FontSize="12" Click="OnSelectAllClicked"
                      ToolTip.Tip="Check every file" />
              <Button Content="None" FontSize="12" Click="OnSelectNoneClicked"
                      ToolTip.Tip="Uncheck every file" />
            </StackPanel>
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="4">
              <Button Content="Drilldown" FontSize="12" Click="OnDrilldownClicked"
                      ToolTip.Tip="Scope the grid to the selected folder" />
              <Button Content="Up" FontSize="12" Click="OnDrillUpClicked"
                      IsEnabled="{Binding IsScoped}"
                      ToolTip.Tip="Scope one folder up" />
            </StackPanel>
          </Grid>
          <TreeView x:Name="Tree" ItemsSource="{Binding Roots}" Background="Transparent"
                    DoubleTapped="OnTreeDoubleTapped" />
        </DockPanel>
      </Border>
      <GridSplitter Grid.Column="1" ResizeDirection="Columns" />
      <DockPanel Grid.Column="2">
        <Border DockPanel.Dock="Top" Padding="6" IsVisible="{Binding IsScoped}">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <TextBlock Text="{Binding ScopeBreadcrumb}" VerticalAlignment="Center" />
            <Button Content="Show all" Click="OnShowAllClicked"
                    ToolTip.Tip="Clear the scope" />
          </StackPanel>
        </Border>
        <DataGrid x:Name="Grid" IsReadOnly="True" AutoGenerateColumns="False"
                  CanUserSortColumns="True" CanUserReorderColumns="False"
                  CanUserResizeColumns="True"
                  Background="#111111" FontSize="12"
                  DoubleTapped="OnRowDoubleTapped" KeyDown="OnGridKeyDown">
          <DataGrid.Columns>
            <DataGridTemplateColumn Header="File" SortMemberPath="File" Width="2*">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <Grid ColumnDefinitions="Auto,*" Margin="12,0"
                        ToolTip.Tip="{Binding FullPath}">
                    <Ellipse Grid.Column="0" Width="8" Height="8" VerticalAlignment="Center"
                             Fill="{Binding SeverityBrush}"
                             ToolTip.Tip="Worst of bandwidth and integrity" />
                    <TextBlock Grid.Column="1" Classes="cell" Text="{Binding File}"
                               Margin="6,0,0,0" TextTrimming="CharacterEllipsis" />
                  </Grid>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
            <DataGridTemplateColumn Header="Bandwidth" SortMemberPath="Bandwidth" Width="Auto">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <TextBlock Classes="cell" Classes.bad="{Binding BandwidthIsBad}"
                             Classes.up="{Binding BandwidthIsUpsampled}"
                             Text="{Binding Bandwidth}" Margin="12,0"
                             ToolTip.Tip="{Binding Error}" />
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
            <DataGridTextColumn Header="Cutoff kHz" Binding="{Binding CutoffKhz, StringFormat='0.0'}"
                                SortMemberPath="CutoffKhz" Width="Auto" />
            <DataGridTextColumn Header="Codec" Binding="{Binding Codec}" Width="Auto" />
            <DataGridTextColumn Header="kbps" Binding="{Binding BitrateKbps, StringFormat='0'}"
                                SortMemberPath="BitrateKbps" Width="Auto" />
            <DataGridTextColumn Header="Hz" Binding="{Binding SampleRateHz}" Width="Auto" />
            <DataGridTextColumn Header="Length" Binding="{Binding DurationText}"
                                SortMemberPath="DurationSeconds" Width="Auto" />
            <DataGridTextColumn Header="Errors" Binding="{Binding DecodeErrors}" Width="Auto" />
            <DataGridTextColumn Header="Dropouts" Binding="{Binding Dropouts}" Width="Auto" />
            <DataGridTemplateColumn Header="Integrity" SortMemberPath="Integrity" Width="Auto">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <StackPanel Orientation="Horizontal" Spacing="6" Margin="12,0">
                    <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                             Fill="{Binding IntegrityBrush}" />
                    <TextBlock Classes="cell" Classes.bad="{Binding IntegrityIsBad}"
                               Text="{Binding Integrity}" />
                  </StackPanel>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
          </DataGrid.Columns>
        </DataGrid>
      </DockPanel>
    </Grid>
  </DockPanel>
</UserControl>
