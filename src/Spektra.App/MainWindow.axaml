<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:Spektra.App.Controls"
        x:Class="Spektra.App.MainWindow"
        Title="Spektra" Width="1100" Height="620"
        Icon="/Assets/spektra-logo.png"
        Background="#111111" DragDrop.AllowDrop="True">
  <Window.Styles>
    <Style Selector="Border.tab">
      <Setter Property="Background" Value="#1C1C1C" />
      <Setter Property="Padding" Value="10,5" />
      <Setter Property="Margin" Value="0,0,2,0" />
      <Setter Property="CornerRadius" Value="4,4,0,0" />
    </Style>
    <Style Selector="Border.tab:pointerover">
      <Setter Property="Background" Value="#262626" />
    </Style>
    <Style Selector="Border.tab.selected">
      <Setter Property="Background" Value="#333333" />
    </Style>
    <Style Selector="Border.tab Button.close">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="4,0" />
      <Setter Property="FontSize" Value="11" />
    </Style>
    <Style Selector="Border.verdict">
      <Setter Property="Padding" Value="12,6" />
      <Setter Property="Background" Value="#1E1E1E" />
    </Style>
    <Style Selector="Border.verdict.lossless">
      <Setter Property="Background" Value="#16311C" />
    </Style>
    <Style Selector="Border.verdict.suspicious">
      <Setter Property="Background" Value="#3A3113" />
    </Style>
    <Style Selector="Border.verdict.lossy">
      <Setter Property="Background" Value="#3A1717" />
    </Style>
    <Style Selector="Border.integrity">
      <Setter Property="Padding" Value="12,6" />
      <Setter Property="Background" Value="#1E1E1E" />
    </Style>
    <Style Selector="Border.integrity.ok">
      <Setter Property="Background" Value="#16311C" />
    </Style>
    <Style Selector="Border.integrity.suspect">
      <Setter Property="Background" Value="#3A3113" />
    </Style>
    <Style Selector="Border.integrity.corrupt">
      <Setter Property="Background" Value="#3A1717" />
    </Style>
  </Window.Styles>
  <DockPanel>
    <DockPanel DockPanel.Dock="Top">
      <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,6,10,0" Spacing="6">
        <TextBlock Text="FFT" VerticalAlignment="Center" Foreground="#888888" FontSize="12" />
        <ComboBox ItemsSource="{Binding FftSizes}" SelectedItem="{Binding FftSize, Mode=TwoWay}"
                  MinWidth="84" FontSize="12" VerticalAlignment="Center"
                  ToolTip.Tip="FFT window size — frequency buckets = size / 2 + 1. Re-analyzes on change." />
      </StackPanel>
      <Menu>
        <MenuItem Header="_File">
          <MenuItem Header="_Open…" Click="OnOpenClicked" InputGesture="Ctrl+O" />
          <MenuItem x:Name="RecentMenu" Header="Open _Recent" />
          <MenuItem Header="_Compare…" Click="OnCompareClicked" />
          <Separator />
          <MenuItem Header="_Save Image…" Click="OnSaveImageClicked" InputGesture="Ctrl+S" />
          <MenuItem Header="Cop_y Image" Click="OnCopyImageClicked" InputGesture="Ctrl+Shift+C" />
          <Separator />
          <MenuItem Header="E_xit" Click="OnExitClicked" />
        </MenuItem>
        <MenuItem Header="_Edit">
          <MenuItem Header="_Preferences…" Click="OnPreferencesClicked" InputGesture="Ctrl+E" />
        </MenuItem>
        <MenuItem Header="_View">
          <MenuItem Header="Average _Spectrum" ToggleType="CheckBox"
                    IsChecked="{Binding ShowSpectrum, Mode=TwoWay}" InputGesture="Ctrl+R" />
        </MenuItem>
        <MenuItem Header="_Analyze">
          <MenuItem Header="Check _Integrity" Click="OnCheckIntegrityClicked" InputGesture="Ctrl+I" />
          <MenuItem Header="Measure _Loudness" Click="OnMeasureLoudnessClicked" InputGesture="Ctrl+L" />
        </MenuItem>
        <MenuItem Header="_Help">
          <MenuItem Header="Check for _Updates…" Click="OnCheckUpdatesClicked" />
          <Separator />
          <MenuItem Header="_About Spektra" Click="OnAboutClicked" />
        </MenuItem>
      </Menu>
    </DockPanel>

    <Border DockPanel.Dock="Top" Background="#5C1010" Padding="12,8"
            IsVisible="{Binding HasShellError}">
      <StackPanel Spacing="6">
        <TextBlock Text="{Binding ShellErrorText}" TextWrapping="Wrap" Foreground="#FFBBBB" />
        <Button Content="Download ffmpeg" Click="OnDownloadFfmpegClicked"
                IsVisible="{Binding FfmpegMissing}" />
      </StackPanel>
    </Border>

    <Border DockPanel.Dock="Top" Background="#123020" Padding="12,8"
            IsVisible="{Binding HasUpdate}">
      <DockPanel>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <Button Content="View release" Click="OnViewReleaseClicked" />
          <Button Content="Dismiss" Click="OnDismissUpdateClicked" />
        </StackPanel>
        <TextBlock Text="{Binding UpdateText}" TextWrapping="Wrap"
                   Foreground="#BFE8CC" VerticalAlignment="Center" />
      </DockPanel>
    </Border>

    <ItemsControl DockPanel.Dock="Top" ItemsSource="{Binding Tabs}"
                  Margin="8,6,8,0" IsVisible="{Binding !ShowHint}">
      <ItemsControl.ItemsPanel>
        <ItemsPanelTemplate>
          <StackPanel Orientation="Horizontal" />
        </ItemsPanelTemplate>
      </ItemsControl.ItemsPanel>
      <ItemsControl.ItemTemplate>
        <DataTemplate>
          <Border Classes="tab" Classes.selected="{Binding IsSelected}"
                  PointerPressed="OnTabPointerPressed">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="{Binding TabTitle}" Foreground="#CCCCCC"
                         VerticalAlignment="Center" />
              <Button Classes="close" Content="✕" Foreground="#888888"
                      Click="OnTabCloseClicked" />
            </StackPanel>
          </Border>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>

    <StackPanel x:Name="DocHost" DockPanel.Dock="Top">
      <DockPanel Margin="12,8,12,4">
        <ComboBox DockPanel.Dock="Right" MinWidth="86" FontSize="12"
                  ItemsSource="{Binding ChannelOptions}"
                  SelectedIndex="{Binding SelectedChannelIndex, Mode=TwoWay}"
                  IsVisible="{Binding HasMultipleChannels}" />
        <TextBlock Text="{Binding HeaderText}" FontSize="13" Foreground="#DDDDDD"
                   VerticalAlignment="Center" />
      </DockPanel>
      <Border Background="#5C1010" Padding="12,8" IsVisible="{Binding HasError}">
        <TextBlock Text="{Binding ErrorText}" TextWrapping="Wrap" Foreground="#FFBBBB" />
      </Border>
      <Border Classes="verdict"
              Classes.lossless="{Binding VerdictIsLossless}"
              Classes.suspicious="{Binding VerdictIsSuspicious}"
              Classes.lossy="{Binding VerdictIsLossy}"
              IsVisible="{Binding HasVerdict}">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <TextBlock Text="Bandwidth:" Foreground="#888888" FontSize="12" VerticalAlignment="Center" />
          <TextBlock Text="{Binding VerdictText}" Foreground="#E6E6E6" FontSize="12"
                     TextWrapping="Wrap" VerticalAlignment="Center" />
        </StackPanel>
      </Border>
      <Border Classes="integrity"
              Classes.ok="{Binding IntegrityIsOk}"
              Classes.suspect="{Binding IntegrityIsSuspect}"
              Classes.corrupt="{Binding IntegrityIsCorrupt}"
              IsVisible="{Binding HasIntegrity}">
        <TextBlock Text="{Binding IntegrityText}" Foreground="#E6E6E6" FontSize="12"
                   TextWrapping="Wrap" VerticalAlignment="Center" />
      </Border>
      <Border Background="#1E2A33" Padding="12,6" IsVisible="{Binding HasLoudness}">
        <TextBlock Text="{Binding LoudnessText}" Foreground="#CFE3EC" FontSize="12"
                   TextWrapping="Wrap" VerticalAlignment="Center" />
      </Border>
    </StackPanel>

    <Grid x:Name="CompareHost" DockPanel.Dock="Top" IsVisible="False"
          RowDefinitions="Auto,Auto">
      <DockPanel Grid.Row="0" Margin="12,8,12,4">
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="0">
          <RadioButton GroupName="mode" Content="Both" IsChecked="{Binding ModeBoth, Mode=TwoWay}" />
          <RadioButton GroupName="mode" Content="A" IsChecked="{Binding ModeA, Mode=TwoWay}" Margin="6,0,0,0" />
          <RadioButton GroupName="mode" Content="B" IsChecked="{Binding ModeB, Mode=TwoWay}" Margin="6,0,0,0" />
          <RadioButton GroupName="mode" Content="Diff" IsChecked="{Binding ModeDiff, Mode=TwoWay}" Margin="6,0,0,0" />
        </StackPanel>
        <TextBlock Text="{Binding TabTitle}" FontSize="13" Foreground="#DDDDDD" VerticalAlignment="Center" />
      </DockPanel>
      <Border Grid.Row="1" Background="#5C1010" Padding="12,6" IsVisible="{Binding HasAlignHint}">
        <TextBlock Text="{Binding AlignHint}" TextWrapping="Wrap" Foreground="#FFBBBB" />
      </Border>
    </Grid>

    <TextBlock DockPanel.Dock="Bottom" Text="{Binding StatusText}"
               Margin="12,4" FontSize="11" Foreground="#888888" />

    <DockPanel x:Name="CompareStrip" DockPanel.Dock="Bottom" IsVisible="False" Margin="12,4,12,8">
      <Button DockPanel.Dock="Right" Content="Auto" Click="OnAutoAlignClicked" Margin="8,0,0,0" VerticalAlignment="Center" />
      <Button DockPanel.Dock="Right" Content="Null test" Click="OnNullTestClicked" Margin="8,0,0,0" VerticalAlignment="Center"
              ToolTip.Tip="Time-domain A−B residual over the visible span" />
      <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Spacing="4" Margin="8,0,0,0">
        <Button Content="◀" Click="OnNudgeOffsetLeft" Padding="9,2" VerticalAlignment="Center"
                ToolTip.Tip="Shift B 1 ms earlier" />
        <NumericUpDown ShowButtonSpinner="False" Width="72" FontSize="12"
                       Minimum="-5500" Maximum="5500" Increment="1" FormatString="+0;-0"
                       Value="{Binding OffsetMs, Mode=TwoWay}"
                       ToolTip.Tip="Total offset in ms (type an exact value)" />
        <Button Content="▶" Click="OnNudgeOffsetRight" Padding="9,2" VerticalAlignment="Center"
                ToolTip.Tip="Shift B 1 ms later" />
        <TextBlock VerticalAlignment="Center" Foreground="#888888" Text="ms" />
      </StackPanel>
      <TextBlock DockPanel.Dock="Left" VerticalAlignment="Center" Foreground="#999999" Text="Align" Margin="0,0,8,0" />
      <Grid ColumnDefinitions="Auto,2*,Auto,1*" VerticalAlignment="Center">
        <TextBlock Grid.Column="0" Text="coarse" VerticalAlignment="Center" Foreground="#666666" Margin="0,0,8,0" />
        <Slider Grid.Column="1" Minimum="-5000" Maximum="5000" SmallChange="10" LargeChange="100"
                Value="{Binding CoarseMs, Mode=TwoWay}" ToolTip.Tip="Coarse (±5 s)" />
        <TextBlock Grid.Column="2" Text="fine" VerticalAlignment="Center" Foreground="#666666" Margin="16,0,8,0" />
        <Slider Grid.Column="3" Minimum="-500" Maximum="500" SmallChange="1" LargeChange="25"
                Value="{Binding FineMs, Mode=TwoWay}" ToolTip.Tip="Fine (±500 ms)" />
      </Grid>
    </DockPanel>

    <Panel>
      <controls:SpectrogramView x:Name="Spectro" />
      <controls:CompareSurface x:Name="CompareSurfaceCtl" IsVisible="False" />
      <TextBlock Text="Drop audio files here — or File → Open"
                 IsVisible="{Binding ShowHint}" FontSize="16" Foreground="#666666"
                 HorizontalAlignment="Center" VerticalAlignment="Center" />
    </Panel>
  </DockPanel>
</Window>
