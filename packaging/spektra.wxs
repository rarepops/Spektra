<?xml version="1.0" encoding="UTF-8"?>
<!--
  Minimal per-machine installer for the Spektra GUI. Installs the single
  self-contained spektra.exe to Program Files, adds a Start Menu shortcut, and
  registers an Add/Remove Programs entry. Build from the repo root after
  publishing the GUI to dist\gui-win-x64:

    wix extension add -g WixToolset.UI.wixext
    wix extension add -g WixToolset.Util.wixext
    wix build packaging\spektra.wxs -arch x64 -ext WixToolset.UI.wixext -ext WixToolset.Util.wixext -o dist\artifacts\Spektra-<version>-Setup.msi

  Building with -arch x64 makes ProgramFiles6432Folder resolve to the real
  Program Files (not the x86 folder) for the 64-bit app.
  The UpgradeCode must stay constant across versions so upgrades replace in place.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">
  <Package Name="Spektra" Manufacturer="rarepops" Version="!(bind.FileVersion.spektraExe)"
           UpgradeCode="3F6E162E-15A4-4C40-A0B7-F0CEA4176DF3"
           Scope="perMachine" Compressed="yes">

    <MajorUpgrade DowngradeErrorMessage="A newer version of Spektra is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Icon Id="AppIcon" SourceFile="assets\spektra.ico" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon" />
    <Property Id="ARPURLINFOABOUT" Value="https://github.com/rarepops/Spektra" />

    <StandardDirectory Id="ProgramFiles6432Folder">
      <Directory Id="INSTALLFOLDER" Name="Spektra" />
    </StandardDirectory>
    <StandardDirectory Id="ProgramMenuFolder" />

    <Feature Id="Main" Title="Spektra" Level="1" AllowAbsent="no"
             Description="The Spektra application and its Start Menu shortcut.">
      <Component Id="MainExe" Directory="INSTALLFOLDER">
        <File Id="spektraExe" Source="dist\gui-win-x64\spektra.exe" KeyPath="yes" />
      </Component>
      <Component Id="StartMenuShortcut" Directory="ProgramMenuFolder">
        <Shortcut Id="AppShortcut" Name="Spektra"
                  Target="[INSTALLFOLDER]spektra.exe" WorkingDirectory="INSTALLFOLDER" Icon="AppIcon" />
        <RemoveFolder Id="RemoveProgramMenuFolder" On="uninstall" />
        <RegistryValue Root="HKCU" Key="Software\rarepops\Spektra" Name="installed"
                       Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </Feature>

    <!-- Optional: add the install folder to the system PATH so "spektra" can be
         launched from a terminal. Shown as a toggle on the Custom Setup page and
         removed again on uninstall. -->
    <Feature Id="PathFeature" Title="Add to PATH" Level="1"
             Description="Add Spektra to the system PATH so you can launch it by typing &quot;spektra&quot; in a terminal.">
      <Component Id="PathEntry" Directory="INSTALLFOLDER">
        <Environment Id="SpektraPath" Name="PATH" Value="[INSTALLFOLDER]"
                     Permanent="no" Part="last" Action="set" System="yes" />
        <RegistryValue Root="HKLM" Key="Software\rarepops\Spektra" Name="PathAdded"
                       Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </Feature>

    <!-- Wizard UI: welcome, license, a Custom Setup page (to toggle "Add to
         PATH"), progress, and a finish page. Without this a double-clicked MSI
         shows no dialogs and looks like it did nothing. -->
    <ui:WixUI Id="WixUI_FeatureTree" />
    <WixVariable Id="WixUILicenseRtf" Value="packaging\license.rtf" />

    <!-- Offer to start Spektra straight from the finish page. -->
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT" Value="Launch Spektra now" />
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOX" Value="1" />
    <Property Id="WixShellExecTarget" Value="[#spektraExe]" />
    <CustomAction Id="LaunchApplication" DllEntry="WixShellExec" BinaryRef="Wix4UtilCA_X64"
                  Impersonate="yes" Return="ignore" />
    <UI>
      <Publish Dialog="ExitDialog" Control="Finish" Event="DoAction" Value="LaunchApplication"
               Condition="WIXUI_EXITDIALOGOPTIONALCHECKBOX = 1 and NOT Installed" />
    </UI>
  </Package>
</Wix>
